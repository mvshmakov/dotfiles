home/.ssh/id_rsa*
# TODO: version both in dotfiles-private
home/.ssh/known_hosts
home/.ssh/authorized_keys
home/.bash_history
!home/.tool-versions

tmux/.config/tmux/plugins
!tmux/.config/tmux/plugins/tpm

zed/.config/zed
!zed/.config/zed/settings.json

karabiner/.config/karabiner/assets
karabiner/.config/karabiner/automatic_backups

# ZDOTDIR points into this repo; ignore any zsh runtime state that still
# lands here (compdump caches are redirected in .zshrc, Apple session files
# are disabled in .zshenv, but fresh machines/edge cases may write them)
zsh/.config/zsh/.zcompdump*
zsh/.config/zsh/.zsh_history
zsh/.config/zsh/.zsh_sessions

# ~/Library/LaunchAgents is stowed from here, so every app that registers a
# login item deposits its plist into the repo; only the hand-managed window
# manager agents are tracked, the app-owned rest stays ignored
launchctl/Library/LaunchAgents/*
!launchctl/Library/LaunchAgents/.gitkeep
!launchctl/Library/LaunchAgents/com.asmvik.yabai.plist
!launchctl/Library/LaunchAgents/com.koekeishiya.skhd.plist

# Include VSCode config
!home/.vscode
