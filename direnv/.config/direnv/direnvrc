#!/usr/bin/env bash
# direnv sources this file with bash (its stdlib is bash), so bashisms
# like [[ ]] and `local` are fine here

set -e

# `|| true` keeps `set -e` from killing the whole file when there is no
# usable TERM (editor-spawned direnv, CI): colors just degrade to empty
RED=$(tput setaf 1 2>/dev/null || true)    # Red color
GREEN=$(tput setaf 2 2>/dev/null || true)  # Green color
YELLOW=$(tput setaf 3 2>/dev/null || true) # Yellow color
NORMAL=$(tput sgr0 2>/dev/null || true)    # No color

_log() {
  echo "use_fnm: $1"
}

_warn() {
  echo "use_fnm: ${YELLOW}$1${NORMAL}"
}

_success() {
  echo "use_fnm: ${GREEN}$1${NORMAL}"
}

_error() {
  echo "use_fnm: ${RED}$1${NORMAL}"
  exit 1
}

# Build flags for linking against brewed libraries, e.g. psycopg2 needs
# libpq/openssl: https://stackoverflow.com/a/69403177/12349023
# Scoped per-project (`use brew_libs libpq openssl` in .envrc) instead of
# exported globally from .zprofile, where they affected every compile on the
# machine. Always includes HOMEBREW_PREFIX/(lib|include), per
# https://docs.brew.sh/Homebrew-and-Python#brewed-python-modules
use_brew_libs() {
  local prefix formula
  prefix="${HOMEBREW_PREFIX:-/opt/homebrew}"

  export LDFLAGS="${LDFLAGS:-} -L$prefix/lib"
  export CPPFLAGS="${CPPFLAGS:-} -I$prefix/include"

  for formula in "$@"; do
    if [ ! -d "$prefix/opt/$formula" ]; then
      echo "use_brew_libs: ${YELLOW}$formula is not installed (brew install $formula)${NORMAL}"
      continue
    fi
    export LDFLAGS="$LDFLAGS -L$prefix/opt/$formula/lib"
    export CPPFLAGS="$CPPFLAGS -I$prefix/opt/$formula/include"
  done
}

layout_poetry() {
  local VENV

  VENV=$(dirname "$(poetry run which python)")

  export VIRTUAL_ENV="${VENV%/bin}"
  export POETRY_ACTIVE=1

  PATH_add "$VENV"
}

# https://github.com/direnv/direnv/wiki/Python
layout_uv() {
  if [[ -d ".venv" ]]; then
    VIRTUAL_ENV="$(pwd)/.venv"
  fi

  if [[ -z $VIRTUAL_ENV || ! -d $VIRTUAL_ENV ]]; then
    log_status "No virtual environment exists. Executing \`uv venv\` to create one."
    uv venv
    VIRTUAL_ENV="$(pwd)/.venv"
  fi

  if [ -d ".venv/bin" ]; then
    PATH_add .venv/bin
  elif [ -d ".venv/Scripts" ]; then
    PATH_add .venv/Scripts
  fi
  export UV_ACTIVE=1 # or VENV_ACTIVE=1
  export VIRTUAL_ENV
}

# Manual custom script to setup fnm in direnv
# TODO: submit this script the direnv upstream
# TODO: read engine version from package.json
use_fnm() {
  if [ "$FNM_DIR" = "" ]; then
    # _error exits by itself
    _error "no FNM_DIR found in PATH, so assuming no fnm is installed${NORMAL}"
  fi

  VERSION_ARG="v$1"
  NVMRC_FILE="$PWD"/.nvmrc
  NODE_VERSION_FILE="$PWD"/.node-version

  if [ "$1" != "" ]; then
    _log "using version provided in an argument ($VERSION_ARG)"
    NODE_VERSION="$VERSION_ARG"
  elif [ -f "$NODE_VERSION_FILE" ]; then
    if [ -f "$NVMRC_FILE" ]; then
      _warn "both .nvmrc and .node-version are present. Using .node-version to setup node"
    else
      _log "using .node-version to setup node"
    fi

    watch_file .node-version
    NODE_VERSION="$(cat "$PWD"/.node-version)"
  elif [ -f "$NVMRC_FILE" ]; then
    _log "using .nvmrc to setup node"

    watch_file .nvmrc
    NODE_VERSION="$(cat "$PWD"/.nvmrc)"
  else
    _warn "neither .node-version nor .nvmrc were found, so skipping node setup"
    exit 0
  fi

  if [ ! -x "$FNM_DIR/node-versions/$NODE_VERSION/installation/bin/node" ]; then
    if ! fnm install; then
      _error "Can't install requested Node.js version ($NODE_VERSION)"
    fi
  fi

  use node "$(printf '%s' "$NODE_VERSION" | cut -c2-)"
  _success "Node.js ${NODE_VERSION%?} setup finished"
}
